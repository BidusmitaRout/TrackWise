<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ✅ Dynamic title -->
    <title>
        <%= typeof title !== 'undefined' ? title : "Trackwise" %>
    </title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f4f6f8;
        }
        
        .container {
            max-width: 480px;
            margin: 4rem auto;
            padding: 2rem;
            background: white;
            border-radius: 10px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
        }
        
        h1 {
            margin-top: 0;
        }
        
        .form-group {
            margin-bottom: 1rem;
        }
        
        label {
            display: block;
            margin-bottom: 0.4rem;
            font-weight: 600;
        }
        
        input {
            width: 100%;
            padding: 0.8rem;
            border: 1px solid #d1d5db;
            border-radius: 6px;
        }
        
        button {
            width: 100%;
            padding: 0.9rem;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 1rem;
        }
        
        button:hover {
            background: #1d4ed8;
        }
        
        .message {
            padding: 0.9rem 1rem;
            border-radius: 6px;
            margin-bottom: 1rem;
        }
        
        .error {
            background: #fee2e2;
            color: #b91c1c;
        }
        
        .actions {
            margin-top: 1rem;
            text-align: center;
        }
        
        .actions a {
            color: #2563eb;
            text-decoration: none;
        }
        
        .meta {
            font-size: 0.9rem;
            color: #475569;
            margin-bottom: 1rem;
        }
    </style>
</head>

<body>
    <div class="container">
        <!-- ✅ YAHAN PE HAR PAGE KA CONTENT AAYEGA -->
        <%- body %>
    </div>
</body>

</html>